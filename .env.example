# Copy this file to .env and fill in your values

# HuggingFace token (get from https://huggingface.co/settings/tokens)
# Required to download Indic Parler-TTS model (gated repo)
HF_TOKEN=hf_your_token_here

# LLM provider — "gemini" (default, production) or "ollama" (local
# Qwen for dev without API key). The LLM module is fully isolated —
# see llm/README.md for the contract it follows.
LLM_PROVIDER=gemini

# Shared knobs (apply to both providers)
LLM_TEMPERATURE=0.2

# Ollama settings — only used when LLM_PROVIDER=ollama
# Windows machine local: http://127.0.0.1:11434/api/chat
# Remote machine: http://192.168.1.10:11434/api/chat
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=qwen3:14b
# How long Ollama keeps Qwen resident in VRAM after a request.
# "0"  → unload immediately (good if ComfyUI/SDXL also wants the GPU)
# "5m" → keep warm for 5 min (faster back-to-back generations)
OLLAMA_KEEP_ALIVE=5m

# Gemini settings — only used when LLM_PROVIDER=gemini
# Free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Model options: gemini-2.5-flash (default, best nuance/speed balance),
# gemini-2.0-flash (cheaper), gemini-2.5-pro (best quality, slower)
GEMINI_MODEL=gemini-2.5-flash

# Flask host/port
HOST=0.0.0.0
PORT=5000

# ─── Payments (Razorpay) ──────────────────────────────────────────────
# Self-serve checkout. When KEY_ID + KEY_SECRET are empty the app falls
# back to the manual admin-approved upgrade-request flow (local box).
# Dashboard → Settings → API Keys. Use test keys (rzp_test_...) first.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret: Dashboard → Settings → Webhooks. Subscribe to the
# `payment.captured` (and optionally `order.paid`) events, point the URL
# at https://<your-host>/api/webhooks/razorpay, and paste the secret here.
RAZORPAY_WEBHOOK_SECRET=

# ─── Anti-abuse / security ────────────────────────────────────────────
# Max body size — protects against payload bombing. 1 MB is plenty
# for our text-only API.
MAX_REQUEST_BYTES=1048576

# CORS allowlist (comma-separated). Empty = same-origin only (typical
# for the cloud Flask deploy where the frontend is served from the
# same host). Set to https://sastaspeech.com when frontend lives
# elsewhere.
CORS_ALLOWED_ORIGINS=

# Audio storage knobs (Supabase Storage bucket — see audio_storage.py)
AUDIO_BUCKET=audio
AUDIO_SIGNED_URL_TTL=3600        # signed URL valid for 1 hour
AUDIO_RETENTION_HOURS=24         # auto-prune anything older than this
AUDIO_MAX_PER_USER=5             # keep at most N most-recent files

# ─── Auth (Supabase) — required ────────────────────────────────────
# Everyone signs up the same way; admins (papa, you) get role='admin'
# in the profiles table and bypass quota automatically.
# Get these from Supabase Dashboard → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# Comma-separated emails auto-promoted to role='admin' on sign-in.
# Useful so you/papa don't have to manually run SQL after signup.
ADMIN_EMAILS=

# Roles that skip quota. Default just "admin".
UNLIMITED_ROLES=admin

# Default per-user monthly char allowance (free tier).
DEFAULT_QUOTA_CHARS=1000

# Escape hatch only — set to 1 for one-off local smoke tests before
# Supabase keys exist. NEVER set this in production.
AUTH_DISABLED=0

# TTS provider — "parler" (default, local, free) or "elevenlabs" (API)
# To switch: set this to "elevenlabs" and fill ELEVENLABS_API_KEY below.
# To switch back: set to "parler" (or remove the line) — no other change needed.
TTS_PROVIDER=elevenlabs

# ElevenLabs settings — only used when TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGBDnXBQb
# eleven_v3 (default): renders inline performance tags ([excited],
# [whispers], [sobbing], …) from the emotion pipeline. Falls back to
# eleven_multilingual_v2 if your account lacks v3 access.
ELEVENLABS_MODEL=eleven_v3

# Bark settings — only used when provider=bark
# Default is the full bark model (~3.5GB, cleaner audio).
# Set to "suno/bark-small" for faster but noisier output.
BARK_MODEL=suno/bark
# Inline emotion tags ([laughs], [sighs], etc.) are off by default
# because they generate the actual non-speech sound in the audio.
# Set to "1" if you want experimental tag-driven emotion.
BARK_USE_TAGS=0

# Whisper settings (used by Parler trim path)
# WHISPER_MODEL: small (default, best Hindi accuracy on CPU)
#                tiny | base = faster, less accurate
#                medium = more accurate, much slower
WHISPER_MODEL=small
# WHISPER_DEVICE: cpu (default — runs in parallel with Parler on GPU)
#                 or cuda (faster but contends with TTS for GPU)
WHISPER_DEVICE=cpu
# How many CPU threads whisper may use (only applies when on CPU)
WHISPER_CPU_THREADS=4

# ComfyUI (image generation) — runs as separate service like Ollama
# Start it via D:\ComfyUI\run_nvidia_gpu.bat before using /api/image.
COMFY_HOST=http://127.0.0.1:8188
COMFY_MODEL=sd_xl_base_1.0.safetensors

# IP-Adapter (character consistency) — only used when anchor toggle is on
# WEIGHT 1.0 = strong character lock but scene/pose may stay close to anchor
# WEIGHT 0.55 = balanced — face stays similar, scene/pose follow prompt
# WEIGHT 0.3 = soft hint — character may drift
IPADAPTER_PRESET=STANDARD (medium strength)
IPADAPTER_WEIGHT=0.55
# Options: 'standard' | 'prompt is more important' | 'style transfer'
IPADAPTER_WEIGHT_TYPE=prompt is more important
