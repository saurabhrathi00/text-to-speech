# Copy this file to .env and fill in your values

# HuggingFace token (get from https://huggingface.co/settings/tokens)
# Required to download Indic Parler-TTS model (gated repo)
HF_TOKEN=hf_your_token_here

# Ollama server URL where Qwen is running
# Windows machine local: http://127.0.0.1:11434/api/chat
# Remote machine: http://192.168.1.10:11434/api/chat
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Ollama model name
OLLAMA_MODEL=qwen2.5:7b

# Flask host/port
HOST=0.0.0.0
PORT=5000
