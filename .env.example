# Copy this file to .env and fill in your values

# HuggingFace token (get from https://huggingface.co/settings/tokens)
# Required to download Indic Parler-TTS model (gated repo)
HF_TOKEN=hf_your_token_here

# Ollama server URL where Qwen is running
# Windows machine local: http://127.0.0.1:11434/api/chat
# Remote machine: http://192.168.1.10:11434/api/chat
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Ollama model name
OLLAMA_MODEL=qwen2.5:7b

# Flask host/port
HOST=0.0.0.0
PORT=5000

# TTS provider — "parler" (default, local, free) or "elevenlabs" (API)
# To switch: set this to "elevenlabs" and fill ELEVENLABS_API_KEY below.
# To switch back: set to "parler" (or remove the line) — no other change needed.
TTS_PROVIDER=elevenlabs

# ElevenLabs settings — only used when TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGBDnXBQb
ELEVENLABS_MODEL=eleven_multilingual_v2

# Bark settings — only used when provider=bark
# Default is the full bark model (~3.5GB, cleaner audio).
# Set to "suno/bark-small" for faster but noisier output.
BARK_MODEL=suno/bark
# Inline emotion tags ([laughs], [sighs], etc.) are off by default
# because they generate the actual non-speech sound in the audio.
# Set to "1" if you want experimental tag-driven emotion.
BARK_USE_TAGS=0

# Whisper settings (used by Parler trim path)
# WHISPER_MODEL: tiny (default, fastest) | base | small | medium
WHISPER_MODEL=tiny
# WHISPER_DEVICE: cpu (default — runs in parallel with Parler on GPU)
#                 or cuda (faster but contends with TTS for GPU)
WHISPER_DEVICE=cpu
# How many CPU threads whisper may use (only applies when on CPU)
WHISPER_CPU_THREADS=4
